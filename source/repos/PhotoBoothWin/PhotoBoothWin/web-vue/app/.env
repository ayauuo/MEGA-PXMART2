# ========== 開發／除錯 ==========
# 開發時起始頁面（0=待機 1=選版型 2=拍照 3=結果 4=列印中）
# 設為空或註解則不自動跳轉，維持待機
VITE_DEV_START_PAGE=0

# 預設版型索引（跳過選版型直接進拍照／預覽時使用，0=bk01 1=bk02 2=bk03 3=bk04）
VITE_DEFAULT_TEMPLATE_INDEX=3

# 拍照預覽畫面是否使用預設測試圖（1 或 true 時用 test0.jpg～test3.jpg）
VITE_PREVIEW_USE_TEST_IMAGES=0

# 網站靜音（1 或 true 時不播放倒數音效，僅顯示倒數數字）
VITE_MUTE=0

# 待機畫面輪播（1 或 true 時啟用輪播）
VITE_IDLE_CAROUSEL=0

# 結果畫面：尚未有合成圖時左側是否顯示版型占位（1 或 true 時用 bk01～bk04.png，右側維持 QR／列印 UI）
VITE_RESULT_SHOW_TEMPLATE_PLACEHOLDER=1

# ========== 伺服器／上傳 ==========
# 結果畫面 QR code：掃描後顯示相片／影片下載頁的基底網址（請與實際部署的 download-page 一致）
VITE_DOWNLOAD_PAGE_BASE_URL=https://www.guoli-tw.com/upload_model/download-page/
# 上傳目標網址（主機端上傳圖片／影片時使用）
VITE_UPLOAD_URL=https://www.guoli-tw.com/upload_model/api/upload.php

# ========== 拍照行為 ==========
# 測試模式：1 或 true 時拍照改為 2 秒倒數
VITE_TEST_FAST_COUNTDOWN=0

# 立刻拍：1 或 true 時跳過倒數，強制立即拍攝（設 1 就不用等）
VITE_SHOOT_IMMEDIATE=0

# 只半按快門：1 或 true 時進入拍照畫面只做半按快門對焦、不連拍（用於測試 EDSDK 對焦）。正式版請設 0
VITE_SHOOT_ONLY_HALF_PRESS=0

# 倒數秒數（畫面上顯示 10～1，此值即 10；改成 5 則顯示 5～1）
VITE_COUNTDOWN_SECONDS=10

# 在哪些秒數時觸發單眼對焦（逗號分隔；設 10 表示只對焦一次，設 10,3,1 則對焦三次）
VITE_FOCUS_AT_SECONDS=10,5

# 對焦後 C# 等待鏡頭完成的毫秒數（傳給 trigger_evf_af_with_pause）
VITE_FOCUS_WAIT_AFTER_MS=350

# 第一次對焦完成就拍照：1 或 true 時只對焦一次、立即拍照；0 時顯示完整倒數 10→1
VITE_SHOOT_AFTER_FIRST_FOCUS=0

# 強制拍攝不等待對焦：1 或 true 時一律使用 Completely_NonAF，到時機就拍（不管有無對焦成功）
VITE_FORCE_CAPTURE_WITHOUT_AF=1

# ========== 使用記錄 ==========
# 專案名稱（用於 daily report 使用記錄 CSV）
VITE_PROJECT_NAME="頭文字D"

# 機台名稱（用於 daily report 使用記錄 CSV）
VITE_MACHINE_NAME="頭文字D拍貼機_拍四格"
# 非測試模式下是否寫入使用記錄到 daily report 資料夾（1 或 true 時寫入）
VITE_LOG_USAGE=1


# 結果頁幾秒沒按列印就自動列印（預設 60）
VITE_RESULT_AUTO_PRINT_SEC=60

# 列印中畫面顯示幾秒後回待機並還原（DNP 通常不通知 C#，用此秒數模擬印完；預設 20）
VITE_PRINTING_SHOW_SEC=15

# 測試時不實際列印：1 或 true 時只顯示列印中畫面、不送 DNP、不寫入列印紀錄 CSV
VITE_SKIP_PRINT=0

# 每筆列印紀錄的收款金額（固定值，寫入 CSV 用，例如 100）
VITE_RECEIPT_AMOUNT=100

# 測試時不列印（VITE_SKIP_PRINT=1）時仍寫入列印紀錄 CSV：1 或 true 時測試也會寫 report
VITE_LOG_PRINT_RECORD_WHEN_SKIP=0

# 正式環境請設 0 或 false：不允許雙擊空白鍵開啟開發者測試面板，避免被人跳過流程
VITE_ALLOW_DEV_PANEL=1



# 這個如果啟動的時候可以直接測試濾鏡
VITE_TEST_FILTER_DIRECT=0
VITE_TEST_FILTER_IMAGE=assets\templates\test\S__29212675.jpg